{
  "name": "jinc/wp-acessivel-jinc",
  "description": "WP Acessível JINC — Accessibility enforcement plugin without overlays.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "JINC Apps",
      "email": "dev@jinc.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-dom": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "WpAcessivelJinc\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WpAcessivelJinc\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "disable-tls": true
  }
}
